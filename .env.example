# Variáveis de ambiente do controle de acesso.
# Em produção, defina estas no painel da Vercel (Project → Settings → Environment Variables).
# Localmente, copie para um arquivo .env (não comitado).

# --- Liberação manual de acesso (teste / cortesia) ---
# E-mails liberados manualmente, separados por vírgula (independe do banco).
# Ex: ACCESS_ALLOWED_EMAILS=seu@email.com,amigo@email.com
ACCESS_ALLOWED_EMAILS=

# --- Sessão ---
# Segredo para assinar o cookie de sessão (HMAC). Gere um valor longo e aleatório.
# Ex (no terminal): openssl rand -hex 32
SESSION_SECRET=

# --- Upstash Redis (lista de e-mails que pagaram) ---
# Provisione pela Vercel Marketplace (integração Upstash). Ela injeta estas vars.
# Aceita também os nomes KV_REST_API_URL / KV_REST_API_TOKEN.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Webhook da GGCheckout ---
# Segredo compartilhado: configure o MESMO valor no painel da GGCheckout e aqui.
# O webhook aceita o segredo via ?secret=, header x-webhook-secret ou Authorization: Bearer.
GGCHECKOUT_WEBHOOK_SECRET=stl-mega-2026-x9k2
